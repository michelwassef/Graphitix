{
  "name": "graphitix",
  "version": "1.0.0",
  "description": "Graphitix is a browser-based data visualization and statistical analysis studio with Venn diagrams, box plots, scatter/volcano/MA plots, 3D surfaces, heatmaps, PCA/MDS/t-SNE/UMAP, line charts, ROC/PR curves, survival analysis, histograms, and proportion charts. It includes multi-tab workspaces, publication-ready exports, and .graph session archives.",
  "main": "./index.js",
  "scripts": {
    "test": "jest",
    "test:stats": "jest __tests__/stats.differential.python.test.js __tests__/stats.component.differential.test.js __tests__/stats.matrix.components.test.js __tests__/stats.extended.coverage.test.js",
    "docs:arch-map": "node scripts/generate-architecture-map.js",
    "docs:component-contracts": "node scripts/generate-component-contracts.js",
    "dev:entrypoint": "node scripts/change-entrypoint.js",
    "test:suggest": "node scripts/suggest-tests.js",
    "bench": "node scripts/run-benchmarks.js",
    "e2e:serve": "node scripts/e2e-server.cjs --port 4173",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:sync:version": "npm --prefix desktop run sync:version",
    "desktop:sync": "npm --prefix desktop run sync:web",
    "desktop:build": "npm --prefix desktop run build",
    "desktop:build:portable": "npm --prefix desktop run build:win:portable",
    "desktop:build:installer": "npm --prefix desktop run build:win:nsis",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:contracts": "playwright test e2e/workspace.smoke.spec.js e2e/aggrid.firefox-paste.spec.js e2e/cross-browser.feature-matrix.spec.js",
    "test:e2e:contracts:chromium": "npm run test:e2e:contracts -- --project=chromium",
    "test:e2e:contracts:firefox": "npm run test:e2e:contracts -- --project=firefox",
    "test:e2e:matrix": "playwright test e2e/workspace.exercise.spec.js",
    "test:e2e:matrix:firefox": "playwright test e2e/workspace.exercise.spec.js --project=firefox",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "debug:browser:chromium": "playwright open --browser=chromium http://127.0.0.1:4173/index.html",
    "debug:browser:firefox": "playwright open --browser=firefox http://127.0.0.1:4173/index.html"
  },
  "keywords": [
    "graphitix",
    "visualization",
    "statistics",
    "charts",
    "bioinformatics"
  ],
  "author": "Michel Wassef",
  "license": "MIT",
  "type": "commonjs",
  "files": [
    "index.html",
    "index.js",
    "css/",
    "js/",
    "libs/",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "ag-grid-community": "^32.3.3",
    "chart.js": "^4.4.7",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "jstat": "^1.9.5",
    "jszip": "^3.10.1",
    "svd-js": "^1.1.1"
  }
}
